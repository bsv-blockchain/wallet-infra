{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "out",
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "declaration": true,
    "declarationMap": true,
    "rootDir": ".",
    "composite": true,
    "noImplicitOverride": true
  },
  "include": ["src/**/*", "package.json"],
  "exclude": ["node_modules", "jest.config.ts"],
  "references": []
}